<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_wp" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.wp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <form position="inside">
                <app string="WooCommerce" name="wp_base">
                    <block title="WooCommerce Connection">
                        <setting string="Store URL">
                            <field name="wp_store_url" placeholder="https://myshop.de"/>
                        </setting>
                        <setting string="Consumer Key">
                            <field name="wp_consumer_key" password="True"/>
                        </setting>
                        <setting string="Consumer Secret">
                            <field name="wp_consumer_secret" password="True"/>
                        </setting>
                        <setting string="Webhook API Token"
                                 help="Must match the X-WP-Token header sent by WooCommerce webhooks.">
                            <field name="wp_api_token" password="True"/>
                        </setting>
                    </block>
                </app>
            </form>
        </field>
    </record>
</odoo>
